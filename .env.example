# 飞书 × AI CLI 桥接系统 · 环境变量
# 复制此文件为 .env 并填入真实值

# Bridge Server
BRIDGE_PORT=3456
BRIDGE_HOST=0.0.0.0
BRIDGE_PROGRESS_INTERVAL=30
BRIDGE_TIMEOUT=600
BRIDGE_POLL_INTERVAL=2
BRIDGE_MAX_CONCURRENT=4

# 数据库
DB_PATH=./data/bridge.db

# JWT 认证
JWT_SECRET=your_jwt_secret_change_me

# 管理员默认密码（首次 seed 时使用）
ADMIN_PASSWORD=admin

# 日志
LOG_LEVEL=info
LOG_DIR=./logs
