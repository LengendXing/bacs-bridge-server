{
  "name": "bacs-bridge-server",
  "version": "1.1.13",
  "description": "BACS Bridge Server — 机器人 × AI-CLI 消息桥接系统（支持 Claude Code / Codex）",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate-db.ts",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx scripts/seed-admin.ts",
    "migrate:bindings": "tsx scripts/migrate-bindings.ts",
    "lint": "eslint src/ --ext .ts,.vue",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fingerprintjs/fingerprintjs": "^5.2.0",
    "@larksuiteoapi/node-sdk": "^1.63.0",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.7.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.38.0",
    "express": "^4.21.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-pty": "^1.1.0",
    "otplib": "^12.0.1",
    "pinia": "^2.2.0",
    "qrcode": "^1.5.4",
    "ssh2": "^1.17.0",
    "uuid": "^9.0.1",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "ws": "^8.20.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/ssh2": "^1.15.5",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "autoprefixer": "^10.4.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.0.0",
    "lucide-vue-next": "^0.460.0",
    "postcss": "^8.4.0",
    "radix-vue": "^1.9.0",
    "tailwind-merge": "^2.5.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "vue-tsc": "^2.1.0"
  }
}
